<header class="header">
  <div class="photo-container">
    <img src="favicon.webp" alt="Brady Hawkins" width="40" height="40" class="hero-photo" />
  </div>
  <div class="header-right">
  <a routerLink="/" routerLinkActive="active" [routerLinkActiveOptions]="{ exact: true }">Home</a>
  <a routerLink="/projects" routerLinkActive="active">Projects</a>
    <a href="https://bradyhawkins.leaflet.pub/">Blog </a>
  <button class="icon-btn" (click)="toggleDarkMode()" aria-label="Toggle dark mode">
    <span *ngIf="theme === 'dark'"><i class="fa-solid fa-campground"></i></span>
    <span *ngIf="theme === 'light'"><i class="fa-solid fa-fire"></i></span>
  </button>

  </div>
</header>
